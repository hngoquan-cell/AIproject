        "\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import json\n",
        "\n",
        "from tensorflow.keras.models import load_model\n",
        "from tensorflow.keras.preprocessing.image import load_img\n",
        "\n",
        "\n",
        "SAVE_DIR    = \"/content/drive/MyDrive/saved_model\"\n",
        "MODEL_PATH  = f\"{SAVE_DIR}/best_model.h5\"\n",
        "LABELS_PATH = f\"{SAVE_DIR}/class_labels.json\"\n",
        "\n",
        "IMG_WIDTH, IMG_HEIGHT = 200, 200\n",
        "\n",
        "\n",
        "\n",
        "print(\"⏳ Đang load model...\")\n",
        "model = load_model(MODEL_PATH)\n",
        "print(\"✅ Load model thành công!\\n\")\n",
        "\n",
        "with open(LABELS_PATH, \"r\", encoding=\"utf-8\") as f:\n",
        "    class_labels = json.load(f)\n",
        "\n",
        "print(f\"📋 Các nhãn trong model: {list(class_labels.values())}\\n\")\n",
        "\n",
        "\n",
        "def predict_image(image_path, top_k=3):\n",
        "    \"\"\"\n",
        "    Dự đoán nhãn của 1 ảnh và hiển thị top-k kết quả.\n",
        "\n",
        "    Tham số:\n",
        "        image_path : đường dẫn tới ảnh cần đoán\n",
        "        top_k      : số kết quả hiển thị (mặc định 3)\n",
        "    \"\"\"\n",
        "\n",
        "    img       = load_img(image_path, target_size=(IMG_WIDTH, IMG_HEIGHT))\n",
        "    img_array = np.array(img) / 255.0\n",
        "    img_array = img_array.reshape(1, IMG_WIDTH, IMG_HEIGHT, 3)\n",
        "\n",
        "    preds       = model.predict(img_array, verbose=0)[0]\n",
        "    top_indices = np.argsort(preds)[::-1][:top_k]\n",
        "\n",
        "    best_name       = class_labels[str(top_indices[0])]\n",
        "    best_confidence = preds[top_indices[0]] * 100\n",
        "\n",
        "    plt.figure(figsize=(5, 5))\n",
        "    plt.imshow(img)\n",
        "    plt.axis('off')\n",
        "    plt.title(\n",
        "        f\"Dự đoán: {best_name}\\nĐộ tự tin: {best_confidence:.2f}%\",\n",
        "        fontsize=13, fontweight='bold',\n",
        "        color='green' if best_confidence >= 70 else 'orange'\n",
        "    )\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "    print(f\"🏆 Top {top_k} kết quả dự đoán:\")\n",
        "    print(\"-\" * 40)\n",
        "    for rank, idx in enumerate(top_indices, 1):\n",
        "        bar  = \"█\" * int(preds[idx] * 20)\n",
        "        note = \" ← kết quả\" if rank == 1 else \"\"\n",
        "        print(f\"  {rank}. {class_labels[str(idx)]:<20} \"\n",
        "              f\"{preds[idx]*100:5.2f}%  {bar}{note}\")\n",
        "    print(\"-\" * 40)\n",
        "\n",
        "\n",
        "    if best_confidence < 60:\n",
        "        print(\"⚠️  Độ tự tin thấp — ảnh có thể không rõ hoặc người này chưa có trong dữ liệu train.\")\n",
        "\n",
        "    return best_name, best_confidence\n",
        "\n",
        "\n",
        "\n",
        "image_path = \"/content/nguyen.jpg\"\n",
        "\n",
        "\n",
        "name, confidence = predict_image(image_path, top_k=3)\n",
        "print(f\"\\n✅ Kết quả: {name}  ({confidence:.2f}%)\")\n"
      ]
